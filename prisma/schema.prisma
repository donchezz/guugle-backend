generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model PasswordChange {
  id                 String   @id @default(auto()) @map("_id") @db.ObjectId
  currentPassword    String
  newPassword        String
  confirmNewPassword String
  changedAt          DateTime @default(now())
}